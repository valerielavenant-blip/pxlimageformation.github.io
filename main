<script>
function handleSubmit() {
  const prenom = document.getElementById('prenom').value.trim();
  const nom = document.getElementById('nom').value.trim();
  const email = document.getElementById('email').value.trim();
  const niveau = document.querySelector('input[name="niveau"]:checked');
  const rgpd = document.getElementById('rgpd').checked;

  if (!prenom) { alert('Merci de renseigner ton prénom.'); return; }
  if (!nom)    { alert('Merci de renseigner ton nom.'); return; }
  if (!email || !email.includes('@')) { alert('Merci de renseigner un email valide.'); return; }
  if (!niveau) { alert('Merci de sélectionner ton niveau en 3D.'); return; }
  if (!rgpd)   { alert('Merci d\'accepter la politique de confidentialité.'); return; }

  // Ici : branchement futur vers Mailchimp / Brevo / Airtable / Google Sheets
  console.log({ prenom, nom, email, niveau: niveau.value });

  document.getElementById('form-content').style.display = 'none';
  const s = document.getElementById('success');
  s.style.display = 'flex';
}
</script>

